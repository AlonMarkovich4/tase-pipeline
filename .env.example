# Copy this file to .env and fill in your values
# ---------------------------------------------------

# Supabase project URL  (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/service key  (Settings > API > Project API keys)
SUPABASE_KEY=eyJhbGciOi...

# Table name (default: tase_putcall)
SUPABASE_TABLE=tase_putcall

# Fetch interval in minutes (default: 15)
FETCH_INTERVAL_MINUTES=15

# Run Chrome headless? (default: true)
HEADLESS=true

# Telegram bot token  (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AA...

# Telegram chat/channel ID to send notifications to
TELEGRAM_CHAT_ID=-1001234567890
